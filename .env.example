# OpenAI provider (default). Used when LLM_MODEL is not a claude-* model.
OPENAI_API_KEY=

# Anthropic provider. Required when LLM_MODEL is a claude-* model (e.g. fallback).
# Install the extra first: pip install -e '.[anthropic]'
ANTHROPIC_API_KEY=

# Provider is inferred from LLM_MODEL (claude-* -> anthropic, else openai).
# Set explicitly to override the inference. Optional.
# LLM_PROVIDER=anthropic

# Model id. Examples: gpt-4.1-mini, gpt-5.5, claude-opus-4-8, claude-haiku-4-5.
LLM_MODEL=gpt-4.1-mini

# Sampling temperature. Ignored for models that reject it (gpt-5.x, claude-opus-4.x).
LLM_TEMPERATURE=0

AGENTDB_PATH=.agentdb/index.sqlite
TRACE_PATH=.agentdb/traces.jsonl
